{
  "name": "gddxx-jarvis",
  "productName": "GDDXX-Jarvis",
  "version": "0.3.0",
  "description": "GDDXX-Jarvis: a local desktop Agent that helps you talk, monitor information, and get real work done.",
  "author": "GDDXX-Jarvis Project",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "npm run build:ui && node scripts/start-electron.cjs",
    "start:desktop": "npm run build:ui && node scripts/start-electron.cjs",
    "start:web": "npm run build:ui && node scripts/start-web.cjs",
    "visuals:generate": "node scripts/generate-state-visuals.cjs",
    "build:ui": "vite build --config vite.jarvis.config.mjs",
    "doctor:install": "node scripts/check-install.cjs",
    "doctor:source": "node scripts/check-windows-source.cjs",
    "doctor:web": "node scripts/check-web-install.cjs",
    "repair:electron": "node scripts/repair-electron.cjs",
    "check": "npm run build:ui && node --check electron/main.cjs && node --check electron/preload.cjs && node --check src/core/index.js && node --check src/core/api.js && node --check src/core/grok-build.js && node --check src/core/capabilities/tools/ui.js && node --check src/core/docs.js && node src/core/test-tool-router.js && node scripts/probe-current-tool-surface.cjs && node scripts/probe-news-ticker.cjs && node scripts/probe-engineering-routing.cjs && node scripts/probe-tts-echo-guards.cjs && node scripts/probe-tts-reliability-contract.cjs && node scripts/probe-settings-credential-safety.cjs && node scripts/probe-connection-recovery-contract.cjs && node scripts/probe-composer-contract.cjs && node scripts/probe-conversation-search-contract.cjs && node scripts/probe-keyboard-voice-contract.cjs && node scripts/probe-turn-feedback-contract.cjs && node scripts/probe-conversation-continuity-contract.cjs && node scripts/probe-control-state-contract.cjs && node scripts/probe-voice-surface-contract.cjs && node scripts/probe-news-surface-continuity-contract.cjs && node scripts/probe-first-run-form-contract.cjs && node scripts/probe-public-error-redaction.cjs && node scripts/probe-release-integrity.cjs && node scripts/probe-wake-sensitivity.cjs && node scripts/probe-asr-sensitivity-contract.cjs && node scripts/probe-first-run-setup.cjs && node scripts/probe-conversation-contract.cjs && node scripts/probe-render-accessibility.cjs && node scripts/probe-windows-deployment.cjs",
    "shortcut:desktop": "node scripts/install-desktop-shortcut.cjs",
    "shortcut:web": "node scripts/install-desktop-shortcut.cjs web",
    "grok:install": "node scripts/install-grok-build.cjs",
    "probe:core": "node scripts/probe-core-runtime.cjs",
    "probe:desktop": "node scripts/probe-desktop-e2e.cjs",
    "probe:desktop-close": "node scripts/probe-desktop-close.cjs",
    "probe:wake-sequence": "node scripts/probe-wake-sequence.cjs",
    "probe:wake-sequence:packaged": "set JARVIS_PROBE_PACKAGED=1&& node scripts/probe-wake-sequence.cjs",
    "probe:wake-sensitivity": "node scripts/probe-wake-sensitivity.cjs",
    "probe:api-hardening": "node scripts/probe-server-launcher.cjs scripts/probe-api-hardening.cjs",
    "probe:single-product": "node scripts/probe-single-product.cjs",
    "probe:layout": "node scripts/probe-layout.cjs",
    "probe:acui": "node scripts/probe-acui-workbench.cjs",
    "probe:tool-surface": "node scripts/probe-current-tool-surface.cjs",
    "probe:turn-lifecycle": "node scripts/probe-turn-lifecycle.cjs",
    "probe:desktop-shortcut": "node scripts/probe-desktop-shortcut.cjs",
    "probe:grok-build": "node scripts/probe-grok-build-integration.cjs",
    "probe:readiness": "node scripts/probe-capability-readiness.cjs",
    "probe:readiness-endpoint": "node scripts/probe-readiness-endpoint.cjs",
    "probe:message-gate": "node scripts/probe-message-activation-gate.cjs",
    "probe:config-repair": "node scripts/probe-config-repair.cjs",
    "probe:product-quality": "node scripts/probe-product-quality-launcher.cjs",
    "probe:tool-receipts": "node scripts/probe-tool-receipts.cjs",
    "probe:work-modules": "node scripts/probe-work-modules.cjs",
    "probe:ui-config-state": "node scripts/probe-ui-config-state.cjs",
    "probe:key-intake": "node scripts/probe-key-intake.cjs",
    "probe:asr-route": "node scripts/probe-asr-routing.cjs",
    "probe:asr-real-audio": "node scripts/probe-server-launcher.cjs scripts/probe-asr-real-audio.cjs",
    "monitor:asr-until": "node scripts/monitor-asr-until.cjs",
    "probe:asr-local-defaults": "node scripts/probe-asr-local-defaults.cjs",
    "probe:asr-start": "node scripts/probe-asr-start.cjs",
    "probe:asr-proxy-start": "node scripts/probe-asr-proxy-start.cjs",
    "probe:web-search": "node scripts/probe-web-search-fallback.cjs",
    "probe:vector-memory": "node scripts/probe-vector-memory.cjs",
    "probe:system-tts": "node scripts/probe-system-tts-provider.cjs",
    "voice:install:jarvis": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-jarvis-voice.ps1",
    "voice:install:local-asr": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-local-asr.ps1",
    "probe:jarvis-tts": "node scripts/probe-jarvis-tts.cjs",
    "probe:tts-backend-fallback": "node scripts/probe-tts-backend-fallback.cjs",
    "probe:tts-echo-guards": "node scripts/probe-tts-echo-guards.cjs",
    "probe:settings-safety": "node scripts/probe-settings-credential-safety.cjs",
    "probe:connection-recovery": "node scripts/probe-connection-recovery-contract.cjs",
    "probe:composer": "node scripts/probe-composer-contract.cjs",
    "probe:conversation-search": "node scripts/probe-conversation-search-contract.cjs",
    "probe:keyboard-voice": "node scripts/probe-keyboard-voice-contract.cjs",
    "probe:turn-feedback": "node scripts/probe-turn-feedback-contract.cjs",
    "probe:error-redaction": "node scripts/probe-public-error-redaction.cjs",
    "probe:release-integrity": "node scripts/probe-release-integrity.cjs",
    "probe:packaged-runtime": "node scripts/probe-packaged-runtime.cjs",
    "probe:packaged-experience": "node scripts/probe-packaged-experience-contract.cjs",
    "probe:installer": "node scripts/probe-installer-artifact.cjs",
    "check:ui-contracts": "node scripts/probe-2026-07-22-ui-contracts.cjs",
    "check:2026-07-23-contracts": "node scripts/probe-2026-07-23-contracts.cjs",
    "probe:conversation-continuity-contract": "node scripts/probe-conversation-continuity-contract.cjs",
    "probe:control-state-contract": "node scripts/probe-control-state-contract.cjs",
    "probe:voice-surface-contract": "node scripts/probe-voice-surface-contract.cjs",
    "probe:news-surface-continuity-contract": "node scripts/probe-news-surface-continuity-contract.cjs",
    "probe:first-run-form-contract": "node scripts/probe-first-run-form-contract.cjs",
    "probe:engineering-continuity-contract": "node scripts/probe-engineering-continuity-contract.cjs",
    "probe:settings-continuity-contract": "node scripts/probe-settings-continuity-contract.cjs",
    "probe:tts-continuity-contract": "node scripts/probe-tts-continuity-contract.cjs",
    "probe:reduced-motion-contract": "node scripts/probe-reduced-motion-contract.cjs",
    "probe:message-surface-contract": "node scripts/probe-message-surface-contract.cjs",
    "probe:tts-repeat": "node scripts/probe-tts-repeat.cjs",
    "rebuild:native": "node ./node_modules/electron-builder/cli.js install-app-deps",
    "rebuild:web": "npm rebuild better-sqlite3",
    "postinstall": "node ./node_modules/electron-builder/cli.js install-app-deps",
    "verify:voice-bundle": "node scripts/probe-local-voice-bundle.cjs",
    "pack": "npm run check && npm run check:ui-contracts && npm run check:2026-07-23-contracts && npm run verify:voice-bundle && node scripts/build.cjs --dir && node scripts/probe-packaged-runtime.cjs",
    "dist": "npm run check && npm run check:ui-contracts && npm run check:2026-07-23-contracts && npm run verify:voice-bundle && node scripts/build.cjs --win nsis && npm run probe:installer"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "lucide-react": "^0.542.0",
    "motion": "^12.40.0",
    "ogl": "^1.0.11",
    "openai": "^6.34.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.160.0",
    "wechat-ilink-client": "^0.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^42.7.0",
    "electron-builder": "^26.15.3",
    "vite": "^8.1.5"
  },
  "build": {
    "appId": "com.gddxx.jarvis",
    "productName": "GDDXX-Jarvis",
    "executableName": "GDDXX-Jarvis",
    "artifactName": "GDDXX-Jarvis-Windows-x64-Setup-${version}.${ext}",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      ".python/**",
      "models/**",
      "src/core/voice/**"
    ],
    "files": [
      "electron/**/*",
      ".python/**/*",
      "models/**/*",
      "src/**/*",
      "skills/**/*",
      "sandbox/**/*",
      "systemPrompt.html",
      "turn-trace.html",
      "build/**/*",
      "package.json",
      "!src/core/ui/brain-ui/**/*",
      "!src/ui/jarvis-react/**/*",
      "!src/voice/**/*",
      "!src/**/test-*.js",
      "!src/**/*-dev-server.js",
      "!data/**/*",
      "!dist/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": true,
      "signExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GDDXX-Jarvis",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    }
  }
}
